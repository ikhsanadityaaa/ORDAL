# ── ORDAL Backend Environment ──
# Copy file ini ke .env dan isi nilainya

# Timezone (default Asia/Jakarta)
APP_TIMEZONE=Asia/Jakarta

# Database path (relative to backend/ folder)
DB_PATH=./autoapply.db

# ── Turso (opsional) ──
# Isi kalau backend jalan di host dengan disk ephemeral (mis. Render free tier)
# supaya database tidak hilang tiap restart. Kosongkan kalau deploy di VPS
# biasa (disk permanen) — nanti otomatis pakai sqlite3 lokal seperti biasa.
# Ambil dari: turso db show <nama-db> --url  &  turso db tokens create <nama-db>
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ── Steel.dev (opsional) ──
# Isi kalau host tempat backend jalan RAM-nya kecil (mis. Render free 512MB)
# dan tidak sanggup jalankan Chromium lokal berbarengan dengan FastAPI.
# Browser Playwright akan connect ke Steel.dev alih-alih Chromium lokal.
# Kosongkan kalau deploy di VPS dengan RAM cukup (mis. Oracle ARM 24GB) —
# nanti otomatis pakai Chromium lokal seperti biasa.
# Ambil dari: https://app.steel.dev/settings/api-keys
STEEL_API_KEY=

# CORS origins (kosongkan jika Telegram-only, atau isi domain web jika masih perlu API)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Secrets ──
# Generate dengan: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# Generate dengan: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ── Telegram Bot ──
# Dapatkan token dari @BotFather
TELEGRAM_BOT_TOKEN=
TELEGRAM_POLLING_ENABLED=1

# Jadwal report harian (default 16:00 WIB)
TELEGRAM_REPORT_HOUR=16
TELEGRAM_REPORT_MINUTE=0

# ── Gemini AI ──
# Dapatkan dari https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ── Email (SMTP) fallback ──
# Dipakai jika user belum set email config sendiri via /email command
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
EMAIL_SENDER=
EMAIL_APP_PASSWORD=

# ── Login capture timeout (ms) ──
# Default 5 menit. Naikkan jika internet lambat.
LOGIN_TIMEOUT_MS=300000
